# Required — Twitch API credentials
# Get from https://dev.twitch.tv/console/apps
# Same keys work for both Twitch and IGDB (IGDB is owned by Twitch)
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# Optional — Email alerts on pipeline failure
# Uses Gmail SMTP with an App Password (not your regular password)
# Generate at https://myaccount.google.com/apppasswords
# If not set, alerts are silently skipped — pipeline works fine without them
# ALERT_EMAIL_FROM=your_gmail@gmail.com
# ALERT_EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# ALERT_EMAIL_TO=where_alerts_go@example.com
